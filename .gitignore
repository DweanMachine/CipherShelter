# == CipherShelter .gitignore ==

# Encrypted output files
*.enc

# Key files
*.key
*.pem
*.p12
*.pfx

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
*.cover

# IDEs and editors
.vscode/
.idea/
*.suo
*.user
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Environment variables
.env
.env.*